# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Required. Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# Model to use for covenant classification (Sonnet is the cost/quality sweet spot)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://localhost/racial_covenants

# ── File storage ──────────────────────────────────────────────────────────────
# Root directory for uploaded PDFs and extracted page images.
# Defaults to ./data inside the project root if not set.
DATA_DIR=./data

# ── OCR settings ─────────────────────────────────────────────────────────────
# DPI to use when converting PDF pages to images. 300 is standard for OCR.
PDF_DPI=300

# Pages whose Tesseract confidence falls below this threshold (0.0–1.0) are
# sent to Claude Vision for a second-pass read.
OCR_CONFIDENCE_THRESHOLD=0.5

# Path to the Tesseract binary (only needed if it's not on your system PATH)
# TESSERACT_CMD=/usr/local/bin/tesseract

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Seconds to wait between Claude API calls. Prevents hitting rate limits.
API_RATE_LIMIT_DELAY=0.5
